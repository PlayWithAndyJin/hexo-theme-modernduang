<section class="about-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">ABOUT</span>
      <h2 class="section-title">关于我</h2>
      <p class="section-desc">了解更多关于我的信息</p>
    </div>
    
    <div class="about-profile">
      <div class="about-avatar">
        <img src="<%= theme.profile.avatar %>" alt="<%= config.author %>">
      </div>
      <h3 class="about-name"><%= config.author %></h3>
      <p class="about-motto"><%= theme.profile.motto %></p>
    </div>
    
    <div class="about-card">
      <div class="post-content">
        <% if (page.content) { %>
          <%- page.content %>
        <% } else { %>
          <p>这里是我的个人博客，记录技术思考与生活感悟。</p>
        <% } %>
      </div>
    </div>
  </div>
</section>
