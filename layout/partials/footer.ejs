<%
  var footerSocial = theme.footer.social || {};
  var profileSocial = theme.profile.social || [];
  var githubUrl = '';
  var emailUrl = '';
  profileSocial.forEach(function(item) {
    if (item.icon === 'github') githubUrl = item.url;
    if (item.icon === 'email') emailUrl = item.url;
  });
%>
<footer class="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="footer-logo"><%= config.title %>.</span>
        <% if (theme.footer.powered !== false) { %>
          <span class="footer-credit">
            Powered by <a href="https://hexo.io/" target="_blank" rel="noopener noreferrer">Hexo</a>
            &nbsp;|&nbsp;
            Theme <a href="https://theme.andyjin.website" target="_blank" rel="noopener noreferrer">Modern Duang</a>
          </span>
        <% } %>
      </div>
      <div class="footer-social">
        <% if (footerSocial.travelling !== false) { %>
          <a href="https://www.travellings.cn/go.html" target="_blank" rel="noopener noreferrer" class="footer-travelling" title="开往-友链接力">
            <img src="https://cdn.jsdelivr.net/gh/travellings-link/travellings/assets/logo.gif" alt="开往" width="80">
          </a>
        <% } %>
        <% if (footerSocial.github !== false && githubUrl) { %>
          <a href="<%= githubUrl %>" target="_blank" rel="noopener noreferrer" class="footer-social-icon github" title="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
        <% } %>
        <% if (footerSocial.email !== false && emailUrl) { %>
          <a href="<%= emailUrl %>" class="footer-social-icon email" title="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        <% } %>
        <% var customSocials = footerSocial.custom || []; %>
        <% customSocials.forEach(function(item) { %>
          <a href="<%= item.url %>" class="footer-social-icon custom" title="<%= item.name %>" <% if (item.color) { %>style="--custom-color: <%= item.color %>"<% } %> target="_blank" rel="noopener noreferrer">
            <%- get_icon(item.icon) %>
          </a>
        <% }) %>
      </div>
    </div>
    <div class="footer-bottom">
      <%
        var currentYear = new Date().getFullYear();
        var sinceYear = theme.footer.since;
        var copyrightText = sinceYear && sinceYear !== currentYear
          ? sinceYear + ' - ' + currentYear
          : '' + currentYear;
      %>
      <span class="footer-copyright">&copy; <%= copyrightText %> By <%= theme.footer.author %></span>
      <% var beian = theme.footer.beian || {}; %>
      <% if (beian.icp || beian.moe || beian.chabei) { %>
        <div class="footer-beian">
          <% if (beian.icp) { %>
            <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="beian-item" title="工信部ICP备案">
              <img src="<%- url_for('/img/icp/icp-miit.png') %>" alt="工信部备案" class="beian-icon">
              <span><%= beian.icp %></span>
            </a>
          <% } %>
          <% if (beian.moe) { %>
            <a href="https://icp.gov.moe/?keyword=<%= beian.moe %>" target="_blank" rel="noopener noreferrer" class="beian-item" title="萌ICP备案">
              <img src="<%- url_for('/img/icp/icp-moe.png') %>" alt="萌备案" class="beian-icon">
              <span>萌ICP备<%= beian.moe %>号</span>
            </a>
          <% } %>
          <% if (beian.chabei) { %>
            <a href="https://icp.redcha.cn/beian/ICP-<%= beian.chabei %>.html" target="_blank" rel="noopener noreferrer" class="beian-item" title="茶ICP备案">
              <img src="<%- url_for('/img/icp/icp-chabei.png') %>" alt="茶备案" class="beian-icon">
              <span>茶ICP备<%= beian.chabei %>号</span>
            </a>
          <% } %>
        </div>
      <% } %>
      <% var footerCustom = theme.footer.custom || ''; %>
      <% if (footerCustom) { %>
        <div class="footer-custom">
          <%- footerCustom %>
        </div>
      <% } %>
    </div>
  </div>
</footer>
