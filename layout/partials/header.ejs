<header class="site-header">
  <nav class="nav-container">
    <a href="<%- url_for('/') %>" class="nav-logo">
      <span class="logo-text"><%= config.title %></span>
      <span class="logo-dot">.</span>
    </a>
    
    <ul class="nav-links">
      <% 
        var defaultIcons = {
          '首页': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
          '归档': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>',
          '标签': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>',
          '分类': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>',
          '友链': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>',
          '开往': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="3" width="16" height="14" rx="2"/><path d="M4 10h16"/><path d="M9 17v4"/><path d="M15 17v4"/><circle cx="7.5" cy="14" r="1.5"/><circle cx="16.5" cy="14" r="1.5"/></svg>',
          '关于': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',
          'RSS': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>',
          '更多': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>'
        };
        var dropdownArrow = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12"><polyline points="6 9 12 15 18 9"/></svg>';
        var getMenuConfig = function(name, value) {
          if (typeof value === 'string') {
            return { url: value, icon: defaultIcons[name] || '', external: false, children: null };
          }
          var icon = value.icon || '';
          if (!icon && defaultIcons[name]) {
            icon = defaultIcons[name];
          }
          return { url: value.url || '', icon: icon, external: value.external || false, children: value.children || null };
        };
      %>
      <% for (var name in theme.menu) { %>
        <% var item = getMenuConfig(name, theme.menu[name]); %>
        <% if (item.children) { %>
          <li class="nav-dropdown">
            <a href="javascript:void(0)" class="dropdown-trigger" aria-haspopup="true">
              <span class="nav-icon"><%- item.icon %></span>
              <%= name %>
              <span class="dropdown-arrow"><%- dropdownArrow %></span>
            </a>
            <ul class="dropdown-menu">
              <% for (var childName in item.children) { %>
                <% var childItem = getMenuConfig(childName, item.children[childName]); %>
                <li>
                  <a href="<%- url_for(childItem.url) %>" <% if (childItem.external) { %>target="_blank" rel="noopener noreferrer"<% } %>>
                    <span class="nav-icon"><%- childItem.icon %></span>
                    <%= childName %>
                  </a>
                </li>
              <% } %>
            </ul>
          </li>
        <% } else { %>
          <li>
            <%
              var itemPath = item.url.replace(/^\//, '');
              var isActive;
              if (itemPath === '' || itemPath === 'index.html') {
                isActive = !page.path || page.path === '' || page.path === 'index.html';
              } else {
                isActive = page.path && page.path.indexOf(itemPath) === 0;
              }
            %>
            <a href="<%- url_for(item.url) %>" class="<%= isActive ? 'active' : '' %>" <% if (item.external) { %>target="_blank" rel="noopener noreferrer"<% } %>>
              <span class="nav-icon"><%- item.icon %></span>
              <%= name %>
            </a>
          </li>
        <% } %>
      <% } %>
    </ul>

    <button class="theme-toggle" id="themeToggle" title="切换深色模式" aria-pressed="<%= (theme.dark_mode && theme.dark_mode.default === 'dark') ? 'true' : 'false' %>">
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>

    <button class="mobile-menu-btn" id="mobileMenuBtn" aria-expanded="false" aria-controls="mobileMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>
  
  <!-- 移动端菜单 -->
  <div class="mobile-menu" id="mobileMenu">
    <ul class="mobile-menu-links">
      <% for (var name in theme.menu) { %>
        <% var item = getMenuConfig(name, theme.menu[name]); %>
        <% if (item.children) { %>
          <li class="mobile-dropdown">
            <a href="javascript:void(0)" class="mobile-dropdown-trigger" aria-haspopup="true">
              <span class="nav-icon"><%- item.icon %></span>
              <%= name %>
              <span class="dropdown-arrow"><%- dropdownArrow %></span>
            </a>
            <ul class="mobile-dropdown-menu">
              <% for (var childName in item.children) { %>
                <% var childItem = getMenuConfig(childName, item.children[childName]); %>
                <li>
                  <a href="<%- url_for(childItem.url) %>" <% if (childItem.external) { %>target="_blank" rel="noopener noreferrer"<% } %>>
                    <span class="nav-icon"><%- childItem.icon %></span>
                    <%= childName %>
                  </a>
                </li>
              <% } %>
            </ul>
          </li>
        <% } else { %>
          <li>
            <a href="<%- url_for(item.url) %>" <% if (item.external) { %>target="_blank" rel="noopener noreferrer"<% } %>>
              <span class="nav-icon"><%- item.icon %></span>
              <%= name %>
            </a>
          </li>
        <% } %>
      <% } %>
    </ul>
    <div class="mobile-theme-toggle">
      <button class="theme-toggle" id="mobileThemeToggle" title="切换深色模式" aria-pressed="<%= (theme.dark_mode && theme.dark_mode.default === 'dark') ? 'true' : 'false' %>">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <span>切换主题</span>
      </button>
    </div>
  </div>
</header>

<script>
document.querySelectorAll('.dropdown-trigger').forEach(function(trigger) {
  trigger.addEventListener('click', function(e) {
    e.preventDefault();
    var parent = this.closest('.nav-dropdown');
    var menu = parent.querySelector('.dropdown-menu');
    var isOpen = parent.classList.contains('is-open');
    
    // 关闭所有其他下拉菜单
    document.querySelectorAll('.nav-dropdown.is-open').forEach(function(item) {
      if (item !== parent) {
        item.classList.remove('is-open');
        item.querySelector('.dropdown-menu').style.display = 'none';
      }
    });
    
    if (isOpen) {
      parent.classList.remove('is-open');
      menu.style.display = 'none';
    } else {
      parent.classList.add('is-open');
      menu.style.display = 'block';
    }
  });
});

// 点击其他地方关闭下拉菜单
document.addEventListener('click', function(e) {
  if (!e.target.closest('.nav-dropdown')) {
    document.querySelectorAll('.nav-dropdown.is-open').forEach(function(item) {
      item.classList.remove('is-open');
      item.querySelector('.dropdown-menu').style.display = 'none';
    });
  }
});

// 移动端下拉菜单
document.querySelectorAll('.mobile-dropdown-trigger').forEach(function(trigger) {
  trigger.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation(); // 阻止事件冒泡，防止关闭移动菜单
    var parent = this.closest('.mobile-dropdown');
    var menu = parent.querySelector('.mobile-dropdown-menu');
    var isOpen = parent.classList.contains('is-open');
    
    // 关闭其他已打开的下拉菜单
    document.querySelectorAll('.mobile-dropdown.is-open').forEach(function(item) {
      if (item !== parent) {
        item.classList.remove('is-open');
        var otherMenu = item.querySelector('.mobile-dropdown-menu');
        if (otherMenu) otherMenu.style.display = 'none';
      }
    });
    
    if (isOpen) {
      parent.classList.remove('is-open');
      menu.style.display = 'none';
    } else {
      parent.classList.add('is-open');
      menu.style.display = 'block';
    }
  });
});
</script>
