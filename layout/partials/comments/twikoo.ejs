<% if (theme.comments.enable !== false && page.comment !== false && theme.comments.twikoo.envId) { %>
<div class="post-comments">
  <div class="section-header">
    <span class="section-label">COMMENTS</span>
    <h3 class="section-title">评论区</h3>
  </div>
  <div id="twikoo"></div>
  <script src="https://cdn.jsdelivr.net/npm/twikoo@1.7.14/dist/twikoo.all.min.js" integrity="sha384-Izyo5U1Stcoy88lLPIJacvqHzqYBreJBucdVaYbplRCIPzwskKXUpnL/QP/axIiC" crossorigin="anonymous"></script>
  <script>
    twikoo.init({
      envId: '<%= theme.comments.twikoo.envId %>',
      el: '#twikoo'
    });
  </script>
</div>
<% } %>
