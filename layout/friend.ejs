<%
  var friend = page.friend || {};
  var friendGroups = theme.friendGroups || {};
  var groupIcon = friendGroups[friend.group] || '📁';
%>

<section class="friend-section">
  <div class="container">
    <a href="<%- url_for('/links') %>" class="friend-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      返回友链
    </a>

    <div class="friend-card">
      <div class="friend-header">
        <div class="friend-avatar">
          <% if (friend.avatar) { %>
            <img src="<%= friend.avatar %>" alt="<%= friend.name %>" onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
            <span class="friend-avatar-placeholder" style="display:none;"><%= friend.name.charAt(0) %></span>
          <% } else { %>
            <span class="friend-avatar-placeholder"><%= friend.name.charAt(0) %></span>
          <% } %>
        </div>
        <div class="friend-info">
          <h1 class="friend-name"><%= friend.name %></h1>
          <p class="friend-desc"><%= friend.desc || '' %></p>
          <div class="friend-meta">
            <span class="friend-group"><%= groupIcon %> <%= friend.group || '未分组' %></span>
            <a href="<%= friend.url %>" target="_blank" rel="noopener noreferrer" class="friend-visit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              访问网站
            </a>
            <% if (friend.rss) { %>
              <a href="<%= friend.rss %>" target="_blank" rel="noopener noreferrer" class="friend-rss">
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.37 20 6.18 20 4.99 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
                RSS 订阅
              </a>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <% if (friend.rss) { %>
    <div class="friend-posts">
      <h3 class="friend-posts-title">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        最近文章
      </h3>
      <div class="friend-posts-list" id="friend-posts-list">
        <div class="friend-posts-loading">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24" class="loading-spin"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
          Loading...
        </div>
      </div>
    </div>
    <% } %>
  </div>
</section>

<% if (friend.rss) { %>
<script>
(function() {
  var rssUrl = '<%= friend.rss %>';
  var container = document.getElementById('friend-posts-list');
  if (!rssUrl || !container) return;

  // 多个 RSS 解析服务作为备选
  var apis = [
    'https://api.rss2json.com/v1/api.json?rss_url=' + encodeURIComponent(rssUrl),
    'https://api.feed2json.org/v1/feed.json?url=' + encodeURIComponent(rssUrl)
  ];

  function tryApi(index) {
    if (index >= apis.length) {
      container.innerHTML = '<div class="friend-posts-empty">Unable to load posts</div>';
      return;
    }

    fetch(apis[index])
      .then(function(res) {
        if (!res.ok) throw new Error('HTTP ' + res.status);
        return res.json();
      })
      .then(function(data) {
        var items = data.items || data.feed?.entries || [];
        if (items.length === 0) {
          container.innerHTML = '<div class="friend-posts-empty">No posts</div>';
          return;
        }
        function esc(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
        var html = '';
        items.slice(0, 5).forEach(function(item) {
          var title = item.title || '';
          var link = item.link || item.url || '#';
          var pubDate = item.pubDate || item.published || item.updated || '';
          var date = pubDate ? new Date(pubDate).toLocaleDateString('zh-CN') : '';
          var desc = item.description || item.summary || '';
          desc = desc.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
          if (desc.length > 80) desc = desc.substring(0, 80) + '...';
          html += '<a href="' + esc(link) + '" target="_blank" rel="noopener noreferrer" class="friend-post-item">';
          html += '<span class="friend-post-date">' + date + '</span>';
          html += '<div class="friend-post-info">';
          html += '<span class="friend-post-title">' + esc(title) + '</span>';
          if (desc) {
            html += '<span class="friend-post-desc">' + desc + '</span>';
          }
          html += '</div>';
          html += '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
          html += '</a>';
        });
        container.innerHTML = html;
      })
      .catch(function() {
        tryApi(index + 1);
      });
  }

  tryApi(0);
})();
</script>
<% } %>
