<section class="tags-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">TAGS</span>
      <h2 class="section-title">所有标签</h2>
      <p class="section-desc">探索感兴趣的话题</p>
    </div>
    
    <%
      var maxPosts = 0;
      var minPosts = Infinity;
      site.tags.forEach(function(tag) {
        var visibleCount = tag.posts.filter(function(p) { return is_visible(p); }).length;
        if (visibleCount > maxPosts) maxPosts = visibleCount;
        if (visibleCount < minPosts) minPosts = visibleCount;
      });
      if (maxPosts === 0) maxPosts = 1;
      if (minPosts === Infinity) minPosts = 0;

      function getTagSize(count, max, min) {
        if (max === min) return 'tag-size-md';
        var ratio = (count - min) / (max - min);
        if (ratio >= 0.7) return 'tag-size-lg';
        if (ratio >= 0.4) return 'tag-size-md';
        return 'tag-size-sm';
      }

      function getTagColor(count, max) {
        var ratio = count / max;
        if (ratio >= 0.8) return 'tag-color-hot';
        if (ratio >= 0.5) return 'tag-color-warm';
        if (ratio >= 0.3) return 'tag-color-cool';
        return 'tag-color-cold';
      }

      var tagIcon = theme.tags && theme.tags.icon ? theme.tags.icon : '';
    %>
    
    <div class="tags-cloud">
      <% site.tags.forEach(function(tag) { %>
        <a href="<%- url_for(tag.path) %>" class="tag-item <%= getTagSize(tag.posts.length, maxPosts, minPosts) %> <%= getTagColor(tag.posts.length, maxPosts) %> <% if (tagIcon) { %>has-icon<% } %>">
          <% if (tagIcon) { %>
            <span class="tag-icon"><%- tagIcon %></span>
          <% } %>
          <%= tag.name %>
          <span class="tag-count"><%= tag.posts.filter(function(p) { return is_visible(p); }).length %></span>
        </a>
      <% }) %>
    </div>
    
    <div class="tags-cloud-decoration">
      <span class="tags-cloud-dot"></span>
      <span class="tags-cloud-dot"></span>
      <span class="tags-cloud-dot"></span>
      <span class="tags-cloud-dot"></span>
      <span class="tags-cloud-dot"></span>
    </div>
  </div>
</section>
