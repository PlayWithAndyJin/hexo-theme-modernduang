<div class="post-layout">
  <!-- 目录 -->
  <aside class="post-toc" id="postToc">
    <div class="toc-header">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
      <span>目录</span>
    </div>
    <nav class="toc-content" id="tocContent">
      <!-- 目录内容由 JS 动态生成 -->
    </nav>
  </aside>

  <article class="post">
    <header class="post-header">
      <% if (page.categories && page.categories.length) { %>
        <div class="post-category-top">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          <%= page.categories.first().name %>
        </div>
      <% } %>
      
      <h1 class="post-title"><%= page.title %></h1>
      
      <%
        // 计算文章字数和阅读时间
        var contentText = page.content ? strip_html(page.content).replace(/\s+/g, '') : '';
        var wordCount = contentText.length;
        var readTime = Math.ceil(wordCount / 400);
      %>
      
      <div class="post-meta">
        <span class="post-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <%= date(page.date, 'YYYY-MM-DD') %>
        </span>
        <span class="post-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <%= wordCount %> 字
        </span>
        <span class="post-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          约 <%= readTime %> 分钟
        </span>
        <!-- 注意：busuanzi_value_page_pv 也在 footer.ejs 中渲染（非文章页），修改 ID 需同步两处 -->
        <% if (theme.busuanzi && theme.busuanzi.enable !== false && theme.busuanzi.page_pv !== false) { %>
        <span class="post-meta-item" aria-label="页面阅读量">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span id="busuanzi_value_page_pv" aria-hidden="true">--</span> 次阅读
        </span>
        <% } %>
      </div>
      
      <% if (page.tags && page.tags.length) { %>
        <div class="post-tags">
          <% page.tags.forEach(function(tag) { %>
            <a href="<%- url_for(tag.path) %>" class="tag">#<%= tag.name %></a>
          <% }) %>
        </div>
      <% } %>
    </header>
    
    <div class="post-content">
      <%- page.content %>
    </div>
  
  <!-- 版权信息 -->
  <div class="post-copyright">
    <div class="copyright-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <path d="M14.83 14.83a4 4 0 1 1 0-5.66"/>
      </svg>
    </div>
    <div class="copyright-content">
      <p class="copyright-title">版权声明</p>
      <p class="copyright-text">本文采用 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0</a> 协议进行许可</p>
      <p class="copyright-text">作者：<%= page.author || config.author %> | 来源：<%= config.title %></p>
      <p class="copyright-text">本文链接：<a href="<%- url_for(page.path) %>"><%= config.url.replace(/\/$/, '') + '/' + page.path %></a></p>
      <p class="copyright-note">未经许可，禁止商业转载，转载请注明出处。</p>
    </div>
  </div>
  
  <!-- 文章导航 -->
  <nav class="post-nav">
    <% if (page.prev) { %>
      <a href="<%- url_for(page.prev.path) %>" class="post-nav-prev">
        <span class="post-nav-label">← 上一篇</span>
        <span class="post-nav-title"><%= page.prev.title %></span>
      </a>
    <% } %>
    <% if (page.next) { %>
      <a href="<%- url_for(page.next.path) %>" class="post-nav-next">
        <span class="post-nav-label">下一篇 →</span>
        <span class="post-nav-title"><%= page.next.title %></span>
      </a>
    <% } %>
  </nav>
  
  <!-- 评论区 -->
  <% if (page.comment !== false) { %>
    <%- partial('partials/comments/twikoo') %>
  <% } %>
</article>
</div>
