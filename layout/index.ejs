<!-- Hero 区域 -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-content">
        <div class="hero-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
          BLOG
        </div>
        <h1 class="hero-name"><span><%= config.title %></span></h1>
        <%
          var heroConfig = theme.hero || {};
          var heroText = heroConfig.text || config.description || '记录技术思考与生活感悟，分享有趣的知识与经验';
          if (heroConfig.mode === 'random' && heroConfig.texts && heroConfig.texts.length) {
            heroText = heroConfig.texts[Math.floor(Math.random() * heroConfig.texts.length)];
          }
        %>
        <p class="hero-tagline"><%= heroText %></p>
        <div class="hero-actions">
          <a href="<%- url_for('/archives') %>" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            开始阅读
          </a>
          <a href="<%- url_for('/about') %>" class="btn btn-secondary">了解更多</a>
        </div>
      </div>
      
      <div class="hero-visual">
        <div class="hero-clay-card">
          <div class="clay-shape clay-shape-1"></div>
          <div class="clay-shape clay-shape-2"></div>
          <div class="clay-shape clay-shape-3"></div>
          <div class="profile-card">
            <%
              var profile = theme.profile || {};
              var isExternal = function(url) { return url && !url.startsWith('mailto:') && !url.startsWith('/'); };
            %>
            <a href="<%- url_for('/about') %>" class="profile-avatar">
              <% if (profile.avatar) { %>
              <img src="<%= profile.avatar %>" alt="<%= config.author %>">
              <% } %>
              <span class="profile-status"></span>
            </a>
            <a href="<%- url_for('/about') %>" class="profile-name"><%= config.author %></a>
            <a href="<%- url_for('/about') %>" class="profile-motto"><%= profile.motto %></a>
            <div class="profile-social">
              <% (profile.social || []).forEach(function(item) { %>
                <a href="<%= item.url %>" class="social-icon <%= item.icon %>" title="<%= item.name %>" <% if (isExternal(item.url)) { %>target="_blank" rel="noopener noreferrer"<% } %>>
                  <%- get_icon(item.icon) %>
                </a>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 最新文章 -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">LATEST</span>
      <h2 class="section-title">最新文章</h2>
    </div>
    
    <% 
      var currentYear = new Date().getFullYear();
      var yearPosts = [];
      site.posts.forEach(function(post) {
        if (!is_visible(post)) return;
        if (date(post.date, 'YYYY') == currentYear) {
          yearPosts.push(post);
        }
      });
      // 按日期倒序排列
      yearPosts.sort(function(a, b) {
        return new Date(b.date) - new Date(a.date);
      });
    %>
    
    <div class="cloud-posts">
      <% yearPosts.forEach(function(post, index) { %>
        <a href="<%- url_for(post.path) %>" class="cloud-card cloud-float-<%= index % 5 + 1 %>">
          <span class="cloud-card-date"><%= date(post.date, 'MM-DD') %></span>
          <h3 class="cloud-card-title"><%= post.title %></h3>
          <span class="cloud-card-arrow">→</span>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- 年度计划 -->
<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">PLANS</span>
      <h2 class="section-title"><%= new Date().getFullYear() %> 年度计划</h2>
    </div>
    
    <%
      var plans = theme.plans || [];
      var totalProgress = 0;
      plans.forEach(function(p) {
        totalProgress += (p.done ? 1 : (p.current || 0) / (p.final || 1));
      });
      var progress = plans.length > 0 ? Math.round((totalProgress / plans.length) * 100) : 0;
      var completedCount = plans.filter(function(p) { return p.done; }).length;
      var totalCount = plans.length;
    %>
    
    <div class="plans-section">
      <div class="plans-progress">
        <div class="plans-progress-header">
          <span class="plans-progress-title">完成进度</span>
          <span class="plans-progress-percent"><%= progress %>%</span>
        </div>
        <div class="plans-progress-bar-container">
          <div class="plans-progress-bar" style="width: <%= progress %>%"></div>
        </div>
        <div class="plans-progress-stats">
          已完成 <%= completedCount %> / <%= totalCount %> 项计划
        </div>
      </div>
      
      <div class="plans-list">
        <% plans.forEach(function(plan) {
          var planPercent = plan.done ? 100 : Math.round(((plan.current || 0) / (plan.final || 1)) * 100);
        %>
          <div class="plan-item <%= plan.done ? 'plan-done' : '' %>" style="--progress: <%= planPercent %>%">
            <div class="plan-checkbox">
              <% if (plan.done) { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              <% } %>
            </div>
            <span class="plan-text"><%= plan.text %></span>
            <% if (!plan.done && plan.final > 1) { %>
              <span class="plan-progress-tag"><%= plan.current %>/<%= plan.final %></span>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<!-- 站点数据 -->
<%
  var statsConfig = theme.siteStats || {};
  if (statsConfig.enable !== false) {
    var startDate = new Date(statsConfig.startDate || '2024-03-14');
    var now = new Date();
    var endDate = new Date(startDate);
    endDate.setFullYear(endDate.getFullYear() + 10);

    var diffMs = now - startDate;
    var diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
    var years = Math.floor(diffDays / 365);
    var days = diffDays % 365;

    var totalMs = endDate - startDate;
    var elapsedMs = now - startDate;
    var remainingMs = totalMs - elapsedMs;
    var remainingPercent = Math.max(0, Math.min(100, (remainingMs / totalMs) * 100)).toFixed(2);
%>
<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">STATS</span>
      <h2 class="section-title">站点数据</h2>
    </div>
    <div class="site-stats">
      <div class="site-stat-card stat-uptime">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-label">站点已正常运行</span>
          <div class="stat-value"><span class="stat-number"><%= years %></span> 年 <span class="stat-number"><%= days %></span> 天</div>
        </div>
      </div>
      <div class="site-stat-card stat-countdown">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
            <circle cx="12" cy="12" r="5"/>
          </svg>
        </div>
        <div class="stat-info">
          <span class="stat-label">距离十年之约还有</span>
          <div class="stat-value"><span class="stat-number"><%= remainingPercent %></span>%</div>
          <div class="stat-progress">
            <div class="stat-progress-bar" style="width: <%= remainingPercent %>%"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<% } %>
