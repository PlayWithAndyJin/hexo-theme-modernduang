<section class="categories-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">CATEGORIES</span>
      <h2 class="section-title">所有分类</h2>
      <p class="section-desc">按主题浏览内容</p>
    </div>
    
    <div class="categories-list">
      <% 
        var categoryConfig = theme.categories || {};
        var defaultIcons = [
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>',
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>',
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>'
        ];
        var defaultColors = ['var(--pastel-pink)', 'var(--pastel-blue)', 'var(--pastel-mint)', 'var(--pastel-lilac)', 'var(--pastel-yellow)', 'var(--primary-light)'];
        var defaultTextColors = ['#C25A4A', '#3A7CA5', '#2D8A4E', '#6B5B95', '#B8860B', 'white'];
        var defaultDescs = [
          '探索前沿技术',
          '真实项目经验',
          '生活感悟记录',
          '学习知识整理',
          '视频教程资源',
          '技术交流讨论'
        ];
      %>
      
      <% site.categories.forEach(function(category, index) { %>
        <%
          var config = categoryConfig[category.name] || {};
          var icon = config.icon || defaultIcons[index % defaultIcons.length];
          var color = config.color || defaultColors[index % defaultColors.length];
          var textColor = config.textColor || defaultTextColors[index % defaultTextColors.length];
          var desc = config.desc || defaultDescs[index % defaultDescs.length];
        %>
        <a href="<%- url_for(category.path) %>" class="category-item">
          <div class="category-header">
            <div class="category-icon" style="background: <%= color %>;">
              <span style="color: <%= textColor %>;">
                <%- icon %>
              </span>
            </div>
            <div class="category-info">
              <h3 class="category-name"><%= category.name %></h3>
              <p class="category-desc"><%= desc %></p>
            </div>
          </div>
          <div class="category-footer">
            <div>
              <span class="category-count"><%= category.posts.length %></span>
              <span class="category-count-label">篇文章</span>
            </div>
            <div class="category-arrow">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  </div>
</section>
