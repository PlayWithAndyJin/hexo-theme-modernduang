<section class="archive-section">
  <div class="container">
    <div class="section-header">
      <span class="section-label">ARCHIVES</span>
      <h2 class="section-title">文章归档</h2>
      <p class="section-desc">在这里找到所有精彩内容</p>
    </div>
    
    <% 
      var years = {};
      page.posts.forEach(function(post) {
        var year = date(post.date, 'YYYY');
        if (!years[year]) years[year] = [];
        years[year].push(post);
      });
    %>
    
    <% Object.keys(years).sort().reverse().forEach(function(year) { %>
      <div class="archive-year">
        <h3 class="archive-year-title"><%= year %></h3>
        <ul class="archive-list">
          <% years[year].forEach(function(post) { %>
            <li class="archive-item">
              <span class="archive-date"><%= date(post.date, 'MM-DD') %></span>
              <div class="archive-content">
                <a href="<%- url_for(post.path) %>" class="archive-link"><%= post.title %></a>
                <p class="archive-excerpt"><%= strip_html(post.excerpt || post.content).substring(0, 80) %>...</p>
              </div>
              <% if (post.tags && post.tags.length) { %>
                <div class="archive-tags">
                  <% post.tags.slice(0, 2).forEach(function(tag) { %>
                    <span class="archive-tag"><%= tag.name %></span>
                  <% }) %>
                </div>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </div>
    <% }) %>
    
    <!-- 分页 -->
    <% if (page.prev || page.next) { %>
      <div class="pagination">
        <% if (page.prev) { %>
          <a href="<%- url_for(page.prev_link) %>" class="pagination-btn">← 上一页</a>
        <% } %>
        <% if (page.next) { %>
          <a href="<%- url_for(page.next_link) %>" class="pagination-btn">下一页 →</a>
        <% } %>
      </div>
    <% } %>
  </div>
</section>
