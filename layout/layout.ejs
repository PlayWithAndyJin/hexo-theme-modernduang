<!DOCTYPE html>
<html lang="<%= config.language %>" data-theme="<%= theme.dark_mode && theme.dark_mode.default || 'light' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title ? page.title + ' - ' + config.title : config.title %></title>
  <meta name="description" content="<%= config.description || '' %>">
  <meta property="og:title" content="<%= page.title ? page.title + ' - ' + config.title : config.title %>">
  <meta property="og:description" content="<%= config.description || '' %>">
  <meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
  <meta property="og:url" content="<%= config.url + '/' + page.path %>">
  <% var ogImage = theme.profile.avatar || theme.siteInfo.avatar || ''; %>
  <% if (ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>">
  <% } %>
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="<%= page.title ? page.title + ' - ' + config.title : config.title %>">
  <meta name="twitter:description" content="<%= config.description || '' %>">
  <% if (ogImage) { %>
  <meta name="twitter:image" content="<%= ogImage %>">
  <% } %>
  <% if (theme.favicon) { %>
    <link rel="icon" href="<%- url_for(theme.favicon) %>">
  <% } %>

  <% if (theme.font && theme.font.enable !== false) { %>
    <% var fontConfig = theme.font || {}; %>
    <% var fontHost = fontConfig.host || 'https://fonts.googleapis.com'; %>
    <link rel="preconnect" href="<%= fontHost %>">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <% if (fontConfig.global && fontConfig.global.families && fontConfig.global.families.length) { %>
      <link href="<%= fontHost %>/css2?family=<%= fontConfig.global.families.join('&family=') %>&display=swap" rel="stylesheet">
    <% } else { %>
      <link href="<%= fontHost %>/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <% } %>
  <% } %>

  <link rel="stylesheet" href="<%- url_for('/css/main.css') %>">
  <link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="<%- url_for('/atom.xml') %>">
</head>
<body>
  <%- partial('partials/header') %>

  <main>
    <%- body %>
  </main>

  <%- partial('partials/footer') %>

  <script src="<%- url_for('/js/main.js') %>"></script>
  
  <!-- Mermaid 支持 - 仅在文章启用了 mermaid 时加载 -->
  <% if (page.mermaid) { %>
    <script>
      // 延迟加载 mermaid，避免阻塞页面渲染
      function loadMermaid() {
        var script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js';
        script.onload = function() {
          mermaid.initialize({ 
            startOnLoad: false, 
            theme: 'default',
            securityLevel: 'strict'
          });
          mermaid.run();
        };
        document.body.appendChild(script);
      }
      
      // 页面加载完成后再延迟 1 秒加载 mermaid
      window.addEventListener('load', function() {
        setTimeout(loadMermaid, 1000);
      });
    </script>
  <% } %>
</body>
</html>
